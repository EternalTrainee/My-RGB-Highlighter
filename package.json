{
  "name": "my-rgb-highlighter",
  "displayName": "My RGB Highlighter",
  "description": "My RGB Highlighter",
  "publisher": "EternalTrainee",
  "icon": "images/icon.png",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/EternalTrainee/My-RGB-Highlighter.git"
  },
  "bugs": {
    "url": "https://github.com/EternalTrainee/My-RGB-Highlighter/issues"
  },
  "homepage": "https://github.com/EternalTrainee/My-RGB-Highlighter#readme",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.brilharRGB",
        "title": "Ativar Brilho RGB!"
      },
      {
        "command": "extension.pararBrilho",
        "title": "Desativar Brilho RGB"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "extension.brilharRGB",
          "group": "modification",
          "when": "editorHasSelection"
        },
        {
          "command": "extension.pararBrilho",
          "group": "modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.96.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
